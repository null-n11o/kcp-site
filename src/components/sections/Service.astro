---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Reveal from '@/components/ui/Reveal.astro';
import type { ServiceItem } from '@/i18n/types';

export interface Props {
  heading: string;
  subtitle: string;
  items: ServiceItem[];
  detailLabel?: string;
}

const { heading, subtitle, items, detailLabel = '詳しく見る →' } = Astro.props;
---

<section id="service" class="py-section sm:py-section-lg bg-base-50">
  <div class="section-wrapper">
    <SectionHeading sectionNumber="02" sectionLabel={heading} title={heading} lede={subtitle} />

    <Reveal variant="stagger" class="flex flex-col">
      {items.map((service, i) => (
        <div class="py-5 border-b border-border-subtle">
          <div class="flex gap-5 items-start">
            <span class="font-mono font-black text-accent/40 text-sm w-6 shrink-0 pt-px">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <div class="sm:grid sm:grid-cols-[10rem_1fr] sm:gap-8 sm:items-baseline">
                <p class="font-bold text-text-primary text-sm mb-1 sm:mb-0">
                  {service.title}
                </p>
                <div>
                  <p class="text-text-secondary text-sm leading-relaxed">
                    {service.description}
                  </p>
                  {service.href && (
                    <a
                      href={service.href}
                      class="inline-block mt-2 text-xs text-accent hover:underline"
                    >
                      {detailLabel}
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </Reveal>
  </div>
</section>
