---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Reveal from '@/components/ui/Reveal.astro';
import type { CompanyInfoRow } from '@/i18n/types';

export interface Props {
  heading: string;
  subtitle: string;
  info: CompanyInfoRow[];
}

const { heading, info } = Astro.props;
---

<section id="company" class="py-section sm:py-section-lg bg-base-50">
  <div class="section-wrapper">
    <Reveal>
      <SectionHeading sectionNumber="06" sectionLabel={heading} />
    </Reveal>

    <Reveal delay={100}>
      <div class="border border-border overflow-hidden">
        <table class="w-full">
          <tbody>
            {info.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-base-50' : 'bg-base-100'}>
                <th class="px-6 py-4 text-left text-xs font-medium text-text-secondary w-40 shrink-0 border-r border-border uppercase tracking-wider">
                  {row.label}
                </th>
                <td class="px-6 py-4 text-sm text-text-primary">
                  {row.value}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </Reveal>
  </div>
</section>
