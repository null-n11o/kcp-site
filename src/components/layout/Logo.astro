---
/**
 * KCP ロゴマーク。
 * 公式ロゴ（公式SVGを背景透過・トリミング・最適化したもの）を public/logo.svg として配置し、
 * 外部参照する。全ページのヘッダー/フッターで使うため、インラインせず1ファイルをキャッシュ共有する。
 * ※ astro:assets の <Image> は SVG を処理できない（ラスター専用）ため、ここは意図的に <img> を使う。
 */
export interface Props {
  /** 追加クラス（サイズは height で指定するのが推奨。例: class="h-9 w-auto"） */
  class?: string;
  /** alt テキスト。装飾用途（リンク側に別途ラベルがある等）では空文字にする */
  title?: string;
}

const { class: className = 'h-9 w-auto', title = 'KCP' } = Astro.props;
---

<img src="/logo.svg" alt={title} class={className} width="118" height="90" decoding="async" />
