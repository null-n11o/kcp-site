---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { getSortedPosts } from '@/utils/blog';
import { useTranslations } from '@/i18n/index';

const t = useTranslations('en');

const allPosts = await getCollection('blog_en');
const posts = getSortedPosts(allPosts);
---

<PageLayout
  title={t.blog.pageTitle}
  description={t.blog.pageDescription}
  localeSwitchHref="/blog/"
  breadcrumbs={[
    { name: t.breadcrumb.home, url: 'https://kcp-8.com/en/' },
    { name: t.breadcrumb.blog, url: 'https://kcp-8.com/en/blog/' },
  ]}
  alternates={[
    { hreflang: 'ja', url: 'https://kcp-8.com/blog/' },
    { hreflang: 'en', url: 'https://kcp-8.com/en/blog/' },
  ]}
>
  <div class="section-wrapper pt-32 pb-16">
    <div data-reveal="fade-up">
      <p class="text-xs font-mono font-medium text-accent tracking-[0.15em] uppercase border-b border-border pb-3 mb-8">
        Blog
      </p>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-white mb-4">Blog</h1>
      <p class="text-text-secondary mb-10">{t.blog.pageSubtitle}</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-text-muted text-center py-16">{t.blog.noPostsMessage}</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal="stagger">
        {posts.map(post => (
          <PostCard post={post} locale="en" />
        ))}
      </div>
    )}
  </div>
</PageLayout>
