---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Service from '@/components/sections/Service.astro';
import MVV from '@/components/sections/MVV.astro';
import Strength from '@/components/sections/Strength.astro';
import BlogPreview from '@/components/sections/BlogPreview.astro';
import Company from '@/components/sections/Company.astro';
import Contact from '@/components/sections/Contact.astro';
import { useTranslations } from '@/i18n/index';
import { getSortedPosts } from '@/utils/blog';

const t = useTranslations('ja');

const allPosts = await getCollection('blog');
const featuredPosts = getSortedPosts(allPosts).slice(0, 3);
---

<PageLayout
  title="ホーム"
  alternates={[
    { hreflang: 'ja', url: 'https://kcp.co.jp/' },
    { hreflang: 'en', url: 'https://kcp.co.jp/en/' },
    { hreflang: 'x-default', url: 'https://kcp.co.jp/' },
  ]}
>
  <Hero
    eyebrow={t.hero.eyebrow}
    headlinePre={t.hero.headlinePre}
    headlineAccent={t.hero.headlineAccent}
    headlinePost={t.hero.headlinePost}
    subtext={t.hero.subtext}
    primaryCta={t.hero.primaryCta}
    secondaryCta={t.hero.secondaryCta}
  />
  <Service
    heading={t.service.heading}
    subtitle={t.service.subtitle}
    items={t.service.items}
  />
  <MVV
    missionLabel={t.mvv.missionLabel}
    mission={t.mvv.mission}
    visionLabel={t.mvv.visionLabel}
    vision={t.mvv.vision}
    valuesLabel={t.mvv.valuesLabel}
    values={t.mvv.values}
  />
  <Strength
    heading={t.strength.heading}
    subtitle={t.strength.subtitle}
    items={t.strength.items}
  />
  <BlogPreview
    posts={featuredPosts}
    heading={t.blog.sectionHeading}
    subtitle={t.blog.sectionSubtitle}
    viewAllLabel={t.blog.viewAll}
    blogHref="/blog/"
  />
  <Company
    heading={t.company.heading}
    subtitle={t.company.subtitle}
    info={t.company.info}
  />
  <Contact
    label={t.contact.label}
    heading={t.contact.heading}
    subtext={t.contact.subtext}
    btnLabel={t.contact.btnLabel}
    formUrl="https://docs.google.com/forms/d/e/1FAIpQLSd2ycZEAgr4DpONjfTUOgKXUJ7cZTN5rNKaXy5WdyitG4Wqqg/viewform?usp=dialog"
  />
</PageLayout>
