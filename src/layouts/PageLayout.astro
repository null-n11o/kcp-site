---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import '@/styles/global.css';
import type { BreadcrumbItem } from '@/utils/schema';
import type { AlternateUrl } from './BaseLayout.astro';
import { useTranslations } from '@/i18n/index';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: Date;
  author?: string;
  authorUrl?: string;
  tags?: string[];
  breadcrumbs?: BreadcrumbItem[];
  alternates?: AlternateUrl[];
  localeSwitchHref?: string;
}

const props = Astro.props;
const locale = (Astro.currentLocale ?? 'ja') as 'ja' | 'en';
const t = useTranslations(locale);
const { localeSwitchHref } = props;
---

<BaseLayout {...props}>
  <Header locale={locale} t={t} localeSwitchHref={localeSwitchHref} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} t={t} />
</BaseLayout>
